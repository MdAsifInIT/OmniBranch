{
  "name": "omnibranch",
  "version": "0.2.0",
  "description": "Deterministic, provider-neutral orchestration and universal Agent Skill installer.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MdAsifInIT/OmniBranch.git",
    "directory": "apps/cli"
  },
  "bugs": "https://github.com/MdAsifInIT/OmniBranch/issues",
  "homepage": "https://github.com/MdAsifInIT/OmniBranch#readme",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "omnibranch": "./dist/main.cjs"
  },
  "files": [
    "dist/main.cjs",
    "skill/",
    "docs/assets/brand/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../../skills/omnibranch/scripts/generate-layouts.mjs ../../skills/omnibranch && node ../../scripts/assemble-package.mjs && tsup --config tsup.config.mjs",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1"
  }
}
